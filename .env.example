# Google social login
GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=https://www.monthly-ib.com/googlelogin/
GOOGLE_CALENDAR_CLIENT_ID=replace-me.apps.googleusercontent.com # optional, falls back to GOOGLE_CLIENT_ID when omitted
GOOGLE_CALENDAR_CLIENT_SECRET=replace-me # optional, falls back to GOOGLE_CLIENT_SECRET when omitted
GOOGLE_CALENDAR_REFRESH_TOKEN=replace-me
GOOGLE_CALENDAR_ID=primary

# Finance dashboard integrations
AWS_BILLING_ACCESS_KEY_ID=replace-me
AWS_BILLING_SECRET_ACCESS_KEY=replace-me
AWS_BILLING_REGION=us-east-1
OPENAI_COSTS_API_KEY=replace-me # optional, falls back to OPENAI_API_KEY when omitted
OPENAI_ORGANIZATION_ID=org_replace_me
